{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/api-zod exec tsc -p tsconfig.json && pnpm --filter @workspace/tiktok-downloader run build",
  "outputDirectory": "artifacts/tiktok-downloader/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
